# Local production-mode pilot — copy to .env.production (gitignored).
# Used with: docker compose -f docker-compose.local-pilot.yml --env-file .env.production up -d --build

APP_ENV=production
SECRET_KEY=local-pilot-secret-key-minimum-32-characters

PUBLIC_APP_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost
HTTP_PORT=8080

# Empty = same-origin /api via nginx
VITE_API_BASE_URL=

# Pilot surfaces
ENABLE_ENTERPRISE=true
ENABLE_CLIENT_PORTAL=true
ENABLE_CLIENT_ENROLLMENT=true
ENABLE_IMPORTS=true
ENABLE_AI=true
ENABLE_LLM=false
ENABLE_ML_SCORING=true
ENABLE_LLM_ACCOUNT_RECOMMENDATIONS=false
ENABLE_EMAIL_DELIVERY=true
DOCUMENT_OCR_ENABLED=true

VITE_ENABLE_ENTERPRISE=true
VITE_ENABLE_CLIENT_PORTAL=true
VITE_ENABLE_CLIENT_ENROLLMENT=true
VITE_ENABLE_IMPORTS=true
VITE_ENABLE_AI=true
VITE_ENABLE_LLM=false
VITE_ENABLE_PORTAL_PUSH=false

# Billing (Stripe — use test mode keys from https://dashboard.stripe.com/test/apikeys)
# 1. Create a recurring Price in Stripe and set STRIPE_DEFAULT_PRICE_ID=price_...
# 2. Set STRIPE_SECRET_KEY=sk_test_... and STRIPE_WEBHOOK_SECRET=whsec_...
#    For local webhooks: stripe listen --forward-to localhost:8080/api/v1/billing/webhooks/stripe
# 3. Rebuild api: docker compose -f docker-compose.local-pilot.yml --env-file .env.production up -d --build api web
# 4. Org Admin → Stripe billing → remove pilot record → create customer → start subscription
ENABLE_BILLING=true
ENABLE_BILLING_USAGE_METERING=true
ENABLE_BILLING_INVOICING=true
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_DEFAULT_PRICE_ID=price_REPLACE_ME

# Client enrollment (public /enroll)
ENROLLMENT_ORGANIZATION_SLUG=verdin-demo
ENROLLMENT_SKIP_PAYMENT=true
# STRIPE_ENROLLMENT_PRICE_ID=price_...  # optional override; defaults to STRIPE_DEFAULT_PRICE_ID

# Email delivery (local pilot uses Mailpit — inbox at http://localhost:8025)
# Production: set EMAIL_PROVIDER=sendgrid and EMAIL_SENDGRID_API_KEY, or SMTP creds.
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@ultimatecreditrepair.local
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USE_TLS=false

# Mail-ready dispute letter return address (optional — shown on labels and c/o line)
DISPUTE_RETURN_NAME=Ultimate Credit Repair LLC
DISPUTE_RETURN_ADDRESS_LINE1=123 Business Center Dr
DISPUTE_RETURN_ADDRESS_LINE2=Austin, TX 78701
DISPUTE_RETURN_ADDRESS_LINE3=

POSTGRES_USER=verdin
POSTGRES_PASSWORD=verdin-pilot-local
POSTGRES_DB=verdin_credit

DATABASE_URL=postgresql+asyncpg://verdin:verdin-pilot-local@postgres:5432/verdin_credit
DATABASE_URL_SYNC=postgresql://verdin:verdin-pilot-local@postgres:5432/verdin_credit

REDIS_URL=redis://redis:6379/0
WORKER_QUEUE_NAME=verdin:jobs

MINIO_ROOT_USER=verdin-pilot-minio
MINIO_ROOT_PASSWORD=verdin-pilot-minio-secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=verdin-pilot-minio
MINIO_SECRET_KEY=verdin-pilot-minio-secret
MINIO_BUCKET=verdin-documents
MINIO_SECURE=false
