# Application
APP_ENV=development
APP_VERSION=4.2.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://verdin:verdin@localhost:5432/verdin_credit
DATABASE_URL_SYNC=postgresql://verdin:verdin@localhost:5432/verdin_credit

# Redis
REDIS_URL=redis://localhost:6379/0
WORKER_QUEUE_NAME=verdin:jobs

# Document OCR (API enqueues; worker processes)
DOCUMENT_OCR_ENABLED=true

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=verdin-documents
MINIO_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Feature flags (backend)
ENABLE_AI=false
ENABLE_LLM=false
ENABLE_EMAIL_DELIVERY=false
ENABLE_SMS_DELIVERY=false
ENABLE_IMPORTS=false
ENABLE_ENTERPRISE=false
ENABLE_BILLING=false
ENABLE_COMPLIANCE_ENFORCEMENT=false
ENABLE_CLIENT_PORTAL=false
ENABLE_PORTAL_PUSH=false
ENABLE_MATERIALIZED_REPORTING=false
ENABLE_API_KEY_RATE_LIMIT=false
ENABLE_BILLING_USAGE_METERING=false
ENABLE_SCIM_PROVISIONING=false
ENABLE_PREDICTIVE_ANALYTICS=false
ENABLE_API_DEVELOPER_PORTAL=false
ENABLE_PUBLIC_OAUTH_DEVELOPER_PORTAL=false
ENABLE_OAUTH_MARKETPLACE_PUBLISHING=false
ENABLE_CROSS_ORG_BENCHMARK_ANALYTICS=false
ENABLE_UNREDACTED_CROSS_ORG_BENCHMARK_EXPORT=false
ENABLE_LIVE_UNREDACTED_BENCHMARK_BLOB_EXPORT=false
ENABLE_BATCH_LLM_SUMMARIES=false
ENABLE_BILLING_INVOICING=false
ENABLE_BILLING_INVOICE_COLLECTION=false
ENABLE_STRIPE_INVOICE_PDF=false
ENABLE_IDP_FEDERATION=false
ENABLE_SAML_FEDERATION_METADATA=false
ENABLE_HRIS_BIDIRECTIONAL_SYNC=false
ENABLE_SAML_CERTIFICATE_ROTATION=false
ENABLE_SAML_AUTOMATED_ROTATION=false
ENABLE_SAML_PASSWORDLESS_ENROLLMENT=false
ENABLE_SMS_MARKETING_CAMPAIGNS=false
ENABLE_SMS_MARKETING_DELIVERY=false
ENABLE_SMS_DELIVERABILITY_DASHBOARD=false
ENABLE_LLM_DISPUTE_DRAFT_AUGMENT=false
ENABLE_AGENT_OBSERVABILITY=false
ENABLE_AGENT_EXECUTION=false
ENABLE_DISPUTE_FILING_PREP=false
ENABLE_DISPUTE_BUREAU_SUBMISSION=false
ENABLE_AGENT_EXTERNAL_TOOL_CALLING=false
ENABLE_AGENT_SUPERVISED_LOOPS=false
ENABLE_AGENT_UNSUPERVISED_LOOPS=false
ENABLE_AGENT_ARBITRARY_EXECUTION=false
ENABLE_BUREAU_LIVE_API=false
ENABLE_AUTONOMOUS_BUREAU_FILING=false
ENABLE_FULLY_AUTONOMOUS_BUREAU_API_FILING=false
ENABLE_UNSUPERVISED_AUTONOMOUS_FILING_LOOPS=false
ENABLE_BUREAU_REFILING=false
ENABLE_BUREAU_UNSUPERVISED_REFILING=false
ENABLE_STRIPE_TAX_CALCULATION=false
ENABLE_STRIPE_LIVE_TAX_API=false
ENABLE_STRIPE_CHARGE_RETRY=false
ENABLE_STRIPE_LIVE_CHARGE_RETRY_EXECUTION=false
ENABLE_HRIS_PASSWORDLESS_UI=false
ENABLE_MOBILE_PASSKEY_READINESS=false
ENABLE_NATIVE_MOBILE_PASSKEY_CLIENT=false
ENABLE_MULTI_IDP_BULK_PROVISIONING=false
ENABLE_HRIS_LIFECYCLE_SYNC=false
API_KEY_RATE_LIMIT_PER_MINUTE=60

# LLM provider (requires ENABLE_LLM=true; no external calls until LLM slices ship)
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_ALLOW_EXTERNAL_PII_EXPORT=false
LLM_TIMEOUT_SECONDS=30

# Email delivery scaffold (requires ENABLE_EMAIL_DELIVERY=true)
EMAIL_PROVIDER=none
EMAIL_FROM_ADDRESS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SENDGRID_API_KEY=

# SMS delivery (requires ENABLE_SMS_DELIVERY=true)
# Marketing SMS campaigns require ENABLE_SMS_MARKETING_CAMPAIGNS=true
# Marketing SMS delivery worker requires ENABLE_SMS_MARKETING_DELIVERY=true
# SMS deliverability dashboard requires ENABLE_SMS_DELIVERABILITY_DASHBOARD=true
SMS_PROVIDER=none
SMS_FROM_NUMBER=
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=

# Enterprise identity scaffold (requires ENABLE_ENTERPRISE=true)
ENTERPRISE_SSO_PROVIDER=none
ENTERPRISE_SSO_ISSUER_URL=
ENTERPRISE_SSO_CLIENT_ID=
ENTERPRISE_SSO_CLIENT_SECRET=
ENTERPRISE_SSO_REDIRECT_URI=
ENTERPRISE_MFA_MODE=none
ENTERPRISE_MFA_ISSUER=

# SCIM provisioning scaffold (requires ENABLE_ENTERPRISE=true and OIDC SSO)
SCIM_PROVISIONING_BEARER_TOKEN=

# Stripe billing scaffold (requires ENABLE_BILLING=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_PRICE_ID=

# Portal push scaffold (requires ENABLE_PORTAL_PUSH=true and ENABLE_CLIENT_PORTAL=true)
PORTAL_PUSH_PROVIDER=none
PORTAL_PUSH_VAPID_PUBLIC_KEY=
PORTAL_PUSH_VAPID_PRIVATE_KEY=
PORTAL_PUSH_VAPID_SUBJECT=

# Feature flags (frontend — Vite requires VITE_ prefix)
VITE_ENABLE_AI=false
VITE_ENABLE_LLM=false
VITE_ENABLE_IMPORTS=true
VITE_ENABLE_ENTERPRISE=false
VITE_ENABLE_CLIENT_PORTAL=false
VITE_ENABLE_PORTAL_PUSH=false

# Worker
WORKER_QUEUE_NAME=verdin:jobs
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_SCHEDULER_INTERVAL_SECONDS=60
WORKER_JOB_TIMEOUT_SECONDS=3600
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
