# Application
APP_ENV=development
APP_VERSION=4.2.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://verdin:verdin@localhost:5432/verdin_credit
DATABASE_URL_SYNC=postgresql://verdin:verdin@localhost:5432/verdin_credit

# Redis
REDIS_URL=redis://localhost:6379/0
WORKER_QUEUE_NAME=verdin:jobs

# Document OCR (API enqueues; worker processes)
DOCUMENT_OCR_ENABLED=true

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=verdin-documents
MINIO_SECURE=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Feature flags (backend)
ENABLE_AI=false
ENABLE_LLM=false
ENABLE_EMAIL_DELIVERY=false
ENABLE_IMPORTS=false
ENABLE_ENTERPRISE=false
ENABLE_CLIENT_PORTAL=false

# LLM provider (requires ENABLE_LLM=true; no external calls until LLM slices ship)
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_ALLOW_EXTERNAL_PII_EXPORT=false
LLM_TIMEOUT_SECONDS=30

# Email delivery scaffold (requires ENABLE_EMAIL_DELIVERY=true)
EMAIL_PROVIDER=none
EMAIL_FROM_ADDRESS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SENDGRID_API_KEY=

# Feature flags (frontend — Vite requires VITE_ prefix)
VITE_ENABLE_AI=false
VITE_ENABLE_LLM=false
VITE_ENABLE_IMPORTS=true
VITE_ENABLE_ENTERPRISE=false
VITE_ENABLE_CLIENT_PORTAL=false

# Worker
WORKER_QUEUE_NAME=verdin:jobs
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_JOB_TIMEOUT_SECONDS=3600
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
